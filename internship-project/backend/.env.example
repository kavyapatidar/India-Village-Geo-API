DATABASE_URL="postgresql://username:password@localhost:5432/india_geo_api"
DAILY_API_LIMIT=5000
GEO_CACHE_TTL_SECONDS=600
IMPORT_BATCH_SIZE=10000
JWT_SECRET="replace-with-a-long-random-secret"

# Optional Upstash Redis REST credentials.
# If omitted, the API uses an in-memory fallback for local development.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
